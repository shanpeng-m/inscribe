{
  "name": "inscribe-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:editor",
    "dev:editor": "pnpm --filter inscribe-editor dev",
    "dev:editor:frontend": "pnpm --filter inscribe-editor dev:frontend",
    "dev:editor:host": "pnpm --filter inscribe-editor dev:frontend -- --host 0.0.0.0",
    "dev:site": "pnpm --filter inscribe-site dev",
    "dev:site:host": "pnpm --filter inscribe-site dev -- --host 0.0.0.0",
    "tauri": "pnpm --filter inscribe-editor tauri",
    "tauri:dev": "pnpm --filter inscribe-editor dev",
    "tauri:dev:verbose": "pnpm --filter inscribe-editor tauri:dev:verbose",
    "tauri:info": "pnpm --filter inscribe-editor tauri:info",
    "ios:init": "pnpm --filter inscribe-editor ios:init",
    "ios:dev": "pnpm --filter inscribe-editor ios:dev",
    "ios:dev:host": "pnpm --filter inscribe-editor ios:dev:host",
    "ios:open": "pnpm --filter inscribe-editor ios:open",
    "ios:build": "pnpm --filter inscribe-editor ios:build",
    "rust:check": "pnpm --filter inscribe-editor rust:check",
    "rust:test": "pnpm --filter inscribe-editor rust:test",
    "rust:fmt": "pnpm --filter inscribe-editor rust:fmt",
    "type-check": "pnpm --filter \"*\" type-check",
    "lint": "pnpm --filter inscribe-editor lint:workspace",
    "format": "pnpm --filter inscribe-editor format:workspace",
    "format:check": "pnpm --filter inscribe-editor format:check:workspace",
    "build": "pnpm build:editor",
    "build:frontend": "pnpm build:editor:frontend",
    "build:editor": "pnpm --filter inscribe-editor build",
    "build:editor:frontend": "pnpm --filter inscribe-editor build:frontend",
    "build:site": "pnpm --filter inscribe-site build",
    "preview:site": "pnpm --filter inscribe-site preview"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "turbo": "^2.0.0"
  }
}
