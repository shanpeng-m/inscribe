{
  "name": "inscribe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm tauri build",
    "build:frontend": "vite build",
    "check": "pnpm type-check",
    "dev": "pnpm tauri dev",
    "dev:frontend": "vite",
    "format": "pnpm format:frontend && pnpm format:backend",
    "format:backend": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:backend:check": "cargo fmt --check --manifest-path src-tauri/Cargo.toml",
    "format:check": "pnpm format:frontend:check && pnpm format:backend:check",
    "format:frontend": "biome format --write .",
    "format:frontend:check": "biome format .",
    "ios": "pnpm tauri ios",
    "lint": "pnpm lint:frontend && pnpm lint:backend",
    "lint:backend": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:frontend": "biome lint .",
    "lint:frontend:fix": "biome check --write .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:dev": "tauri dev",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.6",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
