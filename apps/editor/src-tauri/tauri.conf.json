{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inscribe",
  "version": "0.1.0",
  "identifier": "work.shanpeng.inscribe",
  "build": {
    "beforeDevCommand": "pnpm dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "center": true,
        "height": 920,
        "minHeight": 720,
        "minWidth": 1120,
        "resizable": true,
        "title": "Inscribe",
        "width": 1440
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "asset:", "blob:", "data:"],
        "font-src": ["'self'", "data:"],
        "img-src": ["'self'", "asset:", "blob:", "data:", "https:"],
        "style-src": ["'self'", "'unsafe-inline'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "longDescription": "A modern desktop publishing workspace for writing, organizing, and configuring blog content.",
    "shortDescription": "Modern desktop publishing workspace",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
