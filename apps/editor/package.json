{
  "name": "inscribe-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm tauri build",
    "build:frontend": "vite build",
    "dev": "pnpm tauri dev",
    "dev:frontend": "vite",
    "format": "biome check --write src vite.config.ts",
    "format:check": "biome check src vite.config.ts",
    "format:workspace": "biome check --write ../../apps/editor/src ../../apps/editor/vite.config.ts ../../apps/site/src ../../apps/site/scripts ../../apps/site/vite.config.ts ../../packages/core/src",
    "format:check:workspace": "biome check ../../apps/editor/src ../../apps/editor/vite.config.ts ../../apps/site/src ../../apps/site/scripts ../../apps/site/vite.config.ts ../../packages/core/src",
    "ios:build": "tauri ios build",
    "ios:dev": "tauri ios dev",
    "ios:dev:host": "tauri ios dev --host",
    "ios:init": "tauri ios init",
    "ios:open": "tauri ios dev --open",
    "lint": "biome check src vite.config.ts",
    "lint:workspace": "biome check ../../apps/editor/src ../../apps/editor/vite.config.ts ../../apps/site/src ../../apps/site/scripts ../../apps/site/vite.config.ts ../../packages/core/src",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "tauri:dev:verbose": "tauri dev --verbose",
    "tauri:info": "tauri info",
    "type-check": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.6",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
